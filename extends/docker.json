{
	"$schema": "https://docs.renovatebot.com/renovate-schema.json",
	"packageRules": [
		{
			"addLabels": [
				"managers:dockerfile"
			],
			"matchManagers": [
				"dockerfile"
			]
		},
		{
			"addLabels": [
				"managers:docker-compose"
			],
			"matchManagers": [
				"docker-compose"
			]
		},
		{
			"description": "Dockerfile syntax pragma: automerge minor/patch (# syntax=docker/dockerfile:x.y)",
			"matchManagers": [
				"dockerfile"
			],
			"matchDepTypes": [
				"syntax"
			],
			"matchUpdateTypes": [
				"minor",
				"patch"
			],
			"automerge": true
		}
	]
}
