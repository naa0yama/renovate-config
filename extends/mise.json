{
	"$schema": "https://docs.renovatebot.com/renovate-schema.json",
	"customManagers": [
		{
			"description": "mise.toml dependencies with renovate comments",
			"customType": "regex",
			"managerFilePatterns": [
				"/mise\\.toml$/"
			],
			"matchStrings": [
				"## renovate: datasource=(?<datasource>\\S+)\\s+packageName=(?<packageName>\\S+)(?:\\s+versioning=(?<versioning>\\S+))?(?:\\s+automerge=(?<automerge>\\S+))?\\s*\\n\\S+\\s*=\\s*\"(?<currentValue>\\S+)\""
			],
			"depTypeTemplate": "mise-tool"
		}
	],
	"packageRules": [
		{
			"description": "mise-managed tools: automerge minor/patch (dev tools, no production impact)",
			"matchManagers": [
				"mise"
			],
			"matchUpdateTypes": [
				"minor",
				"patch"
			],
			"automerge": true
		},
		{
			"description": "Custom regex mise tools (depType:mise-tool): automerge minor/patch",
			"matchDepTypes": [
				"mise-tool"
			],
			"matchUpdateTypes": [
				"minor",
				"patch"
			],
			"automerge": true
		}
	]
}
